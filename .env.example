# Copy to .env and adjust per environment.
# Generate a new secret: openssl rand -base64 32

JWT_SECRET=
# Optional: previous secret(s) during rotation (comma-separated)
# JWT_SECRET_PREVIOUS=

DB_USER=admin
DB_PASSWORD=change-me
DB_HOST=192.168.0.132
DB_PORT=5432
APP_USER=admin
APP_PASSWORD=change-me
THREADS=10
NET_PORT_BIND_ADDRESS=0.0.0.0
DEVICE_CONTROL_HOST=127.0.0.1
DEVICE_CONTROL_PORT=8443
METRICS_CACHE_MS=5000
PUBLIC_REGISTRATION_PORT=8443
PUBLIC_PORT_HOST_BASE=49000
# Login rate limit (POST /api/v1/authentication), enabled in production by default
# AUTH_RATE_LIMIT_ENABLED=false
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=20

{
    "host": "localhost",
    "port": 8080,
    "paginate": {
        "default": 10,
        "max": 50
    },
    "authentication": {
        "origins": ["localhost:8080", "netportforward.ru"],
        "entity": "user",
        "service": "/api/v1/users",
        "secret": "",
        "authStrategies": ["jwt", "local", "oauth"],
        "jwtOptions": {
            "header": {
                "typ": "access"
            },
            "audience": "localhost",
            "issuer": "feathers",
            "algorithm": "HS256",
            "expiresIn": "1d"
        },
        "local": {
            "usernameField": "login",
            "passwordField": "password"
        }
    },
    "prefix": "/api/v1",
    "version": "0.0.1"
}

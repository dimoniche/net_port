{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Server",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/server/module_net_port_server-0.0.0",
            "args": ["--user", "1"],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Client",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/client/module_net_port_client-0.0.0",
            "args": ["--host_in", "127.0.0.1", "-p_in", "6001", "--host_out", "127.0.0.1", "-p_out", "22"],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Deploy server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceRoot}/web/deploy/main.py",
            "args": [
                "${input:ssh_ip}",
                "${input:ssh_user}",
                "${input:ssh_password}",
                "${input:db_name}",
                "${input:db_user}",
                "${input:db_password}",
                "${input:db_host}",
                "${input:db_port}"
            ],
            "console": "integratedTerminal",
            "inputs": [
                {
                    "id": "ssh_ip",
                    "type": "promptString",
                    "description": "Enter SSH IP address:"
                },
                {
                    "id": "ssh_user",
                    "type": "promptString",
                    "description": "Enter SSH username:"
                },
                {
                    "id": "ssh_password",
                    "type": "promptString",
                    "description": "Enter SSH password:",
                    "password": true
                },
                {
                    "id": "db_name",
                    "type": "promptString",
                    "description": "Enter database name:"
                },
                {
                    "id": "db_user",
                    "type": "promptString",
                    "description": "Enter database username:"
                },
                {
                    "id": "db_password",
                    "type": "promptString",
                    "description": "Enter database password:",
                    "password": true
                },
                {
                    "id": "db_host",
                    "type": "promptString",
                    "description": "Enter database host:"
                },
                {
                    "id": "db_port",
                    "type": "promptString",
                    "description": "Enter database port:"
                }
            ]
        },
        {
            "name": "Build netport image",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceRoot}/web/deploy/build.py",
            "console": "integratedTerminal"
        }
    ]
}